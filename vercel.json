{
    "version": 2,
    "builds": [
      {
        "src": "/server/server.js",
        "use": "@vercel/node"
      }
    ],
    "routes": [
      {
        "src": "/notify",
        "dest": "/server.js"
      },
      {
        "src": "/create-checkout-session",
        "dest": "/server.js"
      },
      {
        "src": "/verify-checkout-session",
        "dest": "/server.js"
      }
    ]
  }